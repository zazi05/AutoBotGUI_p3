<Window x:Class="AutoBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber Assistant" Height="650" Width="900"
        Background="#1E1E2F" Foreground="White">

    <TabControl Background="#1E1E2F" Foreground="White">
        <!-- Chat Tab -->
        <TabItem Header="Chat">
            <Grid Background="#2A2A3D" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Chat history -->
                <RichTextBox x:Name="ChatHistory" Grid.Row="0" IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             Background="#2A2A3D" Foreground="White"
                             BorderBrush="#6A5ACD" BorderThickness="2" Margin="10"/>

                <!-- Chat input -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10">
                    <TextBox x:Name="MessageInput" Width="650" Height="40"
                             Margin="0,0,10,0" Background="#33334D"
                             Foreground="White" BorderBrush="#FFD700"/>
                    <Button x:Name="btnSendMessage" Content="Send" Width="120" Height="40"
                            Background="#6A5ACD" Foreground="White" Click="SendMessage_Click"/>
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- Task Assistant Tab -->
        <TabItem Header="Task Assistant">
            <Border Margin="10" CornerRadius="8"
                    Background="#252540" BorderBrush="#FFD700" BorderThickness="2">
                <StackPanel Margin="10">
                    <TextBlock Text="Task Assistant" FontSize="18" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,10"/>
                    <TextBox x:Name="TaskTitleBox" Text="Task Title" Margin="0,5"/>
                    <TextBox x:Name="TaskDescriptionBox" Text="Task Description" Margin="0,5"/>
                    <TextBox x:Name="TaskReminderBox" Text="Reminder (e.g. 3 days)" Margin="0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="btnAddTask" Content="Add Task" Width="100" Margin="5" Click="AddTask_Click"/>
                        <Button x:Name="btnCompleteTask" Content="Complete" Width="100" Margin="5" Click="CompleteTask_Click"/>
                        <Button x:Name="btnDeleteTask" Content="Delete" Width="100" Margin="5" Click="DeleteTask_Click"/>
                    </StackPanel>
                    <ListBox x:Name="TaskListBox" Margin="0,10" Height="120"/>
                </StackPanel>
            </Border>
        </TabItem>

        <!-- Cybersecurity Quiz Tab -->
        <TabItem Header="Cybersecurity Quiz">
            <Border Margin="10" CornerRadius="8"
                    Background="#252540" BorderBrush="#6A5ACD" BorderThickness="2">
                <StackPanel Margin="10">
                    <TextBlock Text="Cybersecurity Quiz" FontSize="18" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,10"/>
                    <TextBlock x:Name="QuizQuestionText" FontSize="16" Margin="0,5"/>
                    <ListBox x:Name="QuizOptionsList" Margin="0,5"/>
                    <Button x:Name="btnSubmitAnswer" Content="Submit Answer" Click="SubmitAnswer_Click"
                            Margin="0,5" Background="#6A5ACD" Foreground="White"/>
                    <TextBlock x:Name="QuizScoreText" FontSize="14" Margin="0,10"/>
                </StackPanel>
            </Border>
        </TabItem>
    </TabControl>
</Window>
